generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String
  contactno   String
  selectcourse String
  state       String
  createdAt   DateTime @default(now())
}
